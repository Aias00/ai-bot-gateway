{
  "autoDiscoverProjects": true,
  "defaultModel": "gpt-5.3-codex",
  "defaultAgent": "codex-default",
  "defaultEffort": "medium",
  "approvalPolicy": "never",
  "sandboxMode": "workspace-write",
  "runtime": "codex",
  "agents": {
    "codex-default": {
      "model": "gpt-5.3-codex",
      "runtime": "codex",
      "enabled": true,
      "capabilities": {
        "supportsImageInput": true
      }
    },
    "claude-default": {
      "model": "claude-sonnet-4-6",
      "runtime": "claude",
      "enabled": true,
      "capabilities": {
        "supportsImageInput": true
      }
    }
  },
  "bots": {
    "discord-codex-main": {
      "platform": "discord",
      "runtime": "codex",
      "auth": {
        "tokenEnv": "DISCORD_BOT_TOKEN_MAIN"
      },
      "settings": {
        "guildId": "123456789012345678",
        "allowedUserIdsEnv": "DISCORD_ALLOWED_USER_IDS_MAIN",
        "generalChannelId": "123456789012345679",
        "generalCwd": "/absolute/path/to/discord/general"
      },
      "routes": {
        "123456789012345680": {
          "cwd": "/absolute/path/to/discord/repo",
          "agentId": "codex-default"
        }
      }
    },
    "feishu-claude-support": {
      "platform": "feishu",
      "runtime": "claude",
      "auth": {
        "appIdEnv": "FEISHU_APP_ID_SUPPORT",
        "appSecretEnv": "FEISHU_APP_SECRET_SUPPORT",
        "verificationTokenEnv": "FEISHU_VERIFICATION_TOKEN_SUPPORT"
      },
      "settings": {
        "transport": "webhook",
        "webhookPath": "/feishu/support/events",
        "allowedOpenIdsEnv": "FEISHU_ALLOWED_OPEN_IDS_SUPPORT",
        "generalChatId": "oc_xxxxxxxxxxxxxxxxx",
        "generalCwd": "/absolute/path/to/feishu/general"
      },
      "routes": {
        "oc_repo_1": {
          "cwd": "/absolute/path/to/feishu/repo",
          "agentId": "claude-default"
        }
      }
    }
  }
}
